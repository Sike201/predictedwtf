# xAI (Grok) — copy to .env.local; never commit real keys
# https://console.x.ai/
XAI_API_KEY=

# Optional — defaults to grok-4-1-fast-non-reasoning (text + image → text, structured output)
# See https://docs.x.ai/developers/models
# XAI_MODEL=grok-4-1-fast-non-reasoning

# Supabase (server: service role for market creation pipeline)
# SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=

# Solana (browser + server RPC; default devnet)
# NEXT_PUBLIC_NETWORK=devnet
# NEXT_PUBLIC_SOLANA_RPC_URL=

# Automated market engine (server signs mint + pool init on devnet)
# MARKET_ENGINE_AUTHORITY_SECRET=

# Optional — wallet that receives USDC for "Mint YES+NO" (defaults to engine authority)
# MINT_POSITIONS_CUSTODY_PUBKEY=

# Omnipair Anchor program (main deploy: omnixgS8fnqHfCcTGKWj6JtKjzpJZ1Y5y9pyFkQDkYE)
# NEXT_PUBLIC_OMNIPAIR_PROGRAM_ID=

# Team treasury wallet (must match FutarchyAuthority.recipients.team_treasury; needs wSOL ATA + 0.2 SOL pair fee capacity)
# OMNIPAIR_TEAM_TREASURY=

# Set true for real `initialize` (InitializeAndBootstrap) txs — see omnipair-rs programs/omnipair/src/lib.rs
# OMNIPAIR_EXECUTE_INIT=

# Pinata — market cover images (JWT preferred)
# PINATA_JWT=
# PINATA_API_KEY=
# PINATA_API_SECRET=

# Dry run: mock mints + PDAs, no RPC mints (requires Supabase)
# MOCK_CHAIN=1

# Optional default resolver pubkey when client omits resolver
# DEFAULT_RESOLVER_WALLET=
